# .env.docker.example
# Copy this file to .env before running docker compose

# Application Configuration
NODE_ENV=production
PORT=7000
NEXT_PUBLIC_APP_URL=http://localhost:7000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional bucket used by the local-only seed importer
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# Optional local-only seed inputs. Keep the actual files outside git.
# LOCAL_SEED_PRODUCTS_CSV=local/seed-data/products.csv
# LOCAL_SEED_IMAGE_DIR=local/seed-data/images
