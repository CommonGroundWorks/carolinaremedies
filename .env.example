# CarolinaRemedies Environment Variables

# Application configuration
NODE_ENV=development
PORT=7000
HOST=0.0.0.0
NEXT_PUBLIC_APP_URL=http://localhost:7000
NEXT_PUBLIC_APP_NAME=CarolinaRemedies

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional storage bucket used by the local-only seed importer
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# Local-only catalog seed sources (keep these paths gitignored)
LOCAL_SEED_PRODUCTS_CSV=local/seed-data/products.csv
LOCAL_SEED_IMAGE_DIR=local/seed-data/images

# Admin bootstrap — only needed when running scripts/create-admin.ts
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme123

# Optional observability
# SENTRY_DSN=https://your-sentry-dsn